lemma three_dvd_card' (i : Fin 3 ): 3 ∣ Fintype.card (![ZMod 67, ZMod 19, ZMod 43] i)ˣ :=
  match i with
  | 0 => by simp ; decide
  | 1 => by simp ; decide
  | 2 => by
    have : Fintype.card (![ZMod 67, ZMod 19, ZMod 43] 2)ˣ = Fintype.card (ZMod 43)ˣ := by
      refine Fintype.card_congr' ?_
      rfl
    rw [this]
    simp ; decide


lemma matrix_log_alpha : (MatrixLogProd 3 ![ZMod 67, ZMod 19, ZMod 43] φ' (Sum.elim ![ζ₁, ζ₂] (fun (_ : Fin 1) => α)) ζ' hr') =
  ![Sum.elim ![1,0] ![-1], Sum.elim ![(-1 : ZMod 3), -1] ![0], Sum.elim ![0, 1] ![0]] := by
  ext i j
  rw [MatrixLogProd_def]
  fin_cases i
  · fin_cases j
    · exact log_of_zeta11
    · exact log_of_zeta21
    · exact log_of_alpha₁
  · fin_cases j
    · exact log_of_zeta12
    · exact log_of_zeta22
    · exact log_of_alpha₂
  · fin_cases j
    · simp ; exact log_of_zeta31
    · simp ; exact log_of_zeta32
    · simp ; exact log_of_alpha₃

lemma matrix_log_alpha_rank :
  (MatrixLogProd 3 ![ZMod 67, ZMod 19, ZMod 43] φ' (Sum.elim ![ζ₁, ζ₂] (fun (_ : Fin 1) => α)) ζ' hr').rank =
  Fintype.card (Fin 2) + 1 := by
  simp only [Fintype.card_fin]
  refine le_antisymm ?_ ?_
  ·  convert (Matrix.rank_le_card_width (MatrixLogProd 3 ![ZMod 67, ZMod 19, ZMod 43] φ' (Sum.elim ![ζ₁, ζ₂] (fun (_ : Fin 1) => α)) ζ' hr'))
  · refine le_of_eq_of_le ?_ (Matrix.rank_mul_le_left _ ((Sum.elim ![![0,-1,-1], ![0,0,1]] ![![-1,-1,-1]] : Matrix _ _ (ZMod 3))))
    convert Matrix.rank_one.symm
    · simp only [Nat.reduceAdd, Nat.succ_eq_add_one, zero_add, Fintype.card_fin]
    · rw [matrix_log_alpha]
      ext i j
      fin_cases i <;> fin_cases j <;> rfl
    · exact Fin.fintype 3
    · exact strongRankCondition_of_orzechProperty (ZMod 3)

