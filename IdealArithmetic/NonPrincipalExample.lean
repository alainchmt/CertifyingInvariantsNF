  (∃ (e : Fin 2 → ℕ) , (∃ (t : Oˣ) , w = (∏ (i : Fin 2), (![ζ₁, ζ₂] i) ^ (e i)) * t ^ 3)) := by
  have := units_up_to_p_power_of_full_rank_matrix_of_p_not_dvd_torsion (p := 3) ![ZMod 19, ZMod 43] ![ζ₁, ζ₂]
    units_isUnit φe ζ hr three_dvd_card three_ne_dvd_torsion (matrix_log_units_rank) ?_ w
  swap
  · simp only [Nat.succ_eq_add_one, zero_add, Nat.reduceAdd, Fintype.card_fin]
    exact O_units_rank
  obtain ⟨e, t, h1⟩ := this
  obtain ⟨e',h1, t', h2 ⟩ := (nat_up_to_power_of_int_up_to_power (p := 3) units_isUnit (w := w) (by norm_num) e t h1)
  use e' , t'

