  refine le_primes_below_bound_of_PrimesBelowBoundCertificate_le_of_eq (Subalgebra.equivOfEq _ _ O_integral_closure).toRingEquiv PB1556

def 𝔭' : Fin 234 → nonZeroDivisors (Ideal O) := by
  intro i
  have : PB1556.β i ∈ List.ofFn PB1556.β := by
    simp only [List.mem_ofFn, exists_apply_eq_apply]
  refine Ideal.toNonZeroDivisorOfNeZero ((PB1556.β) i)
    (fun hc => ((zero_ne_mem_of_PrimesBelowCertificate_Fn _ PB1556) (hc ▸ this) ))

