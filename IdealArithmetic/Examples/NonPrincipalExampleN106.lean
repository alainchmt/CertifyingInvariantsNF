noncomputable def P : ℤ[X] := X^5 + 10*X^3 - 40*X^2 - 15*X - 232

def K := AdjoinRoot (map (algebraMap ℤ ℚ) P)

lemma P_irreducible : Irreducible P := sorry
lemma P_degree : P.natDegree = 5 := sorry
lemma P_monic : Monic P := sorry

